	fileedit(gunModel)
	[
		exec
		{
			reldir("pc/main/xmodel/")
			width(500)
		}
	]
	fileedit(handModel)
	[
		exec
		{
			label("Default Hand Model")
		
			reldir("pc/main/xmodel/")
			width(500)
		}
	]
	checkbox(isHandModelOverridable)
	[
		exec
		{
			label("Update Hand Model From Script")
			tooltip("If checked then the hand model can be updated from script")
			width(30)
		}
	]
