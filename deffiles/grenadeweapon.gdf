	hcontainer
	{
		floatedit(swayMaxAngle, 0.05, 0.1)
		[
			exec
			{
				width(270)               // optional custom width
				labelwidth(170)          // optional custom width
			}
		]
	}
	
	hcontainer
	{
		floatedit(swayLerpSpeed, 0.05, 0.1)
		[
			exec
			{
				width(270)               // optional custom width
				labelwidth(170)          // optional custom width
			}
		]
	}
	
